---
import "../styles/global.css";

const navItems = [
  { href: "#section01", label: "はじめに" },
  { href: "#section02", label: "略歴" },
  { href: "#section03", label: "業務経歴" },
  { href: "#section04", label: "強み" },
  { href: "#section05", label: "成果物" },
];
---

<html lang="ja" data-theme="system">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/gen-interface-jp@latest/cdn/300.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/gen-interface-jp@latest/cdn/400.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/gen-interface-jp@latest/cdn/500.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/gen-interface-jp@latest/cdn/700.css"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@300;400;500;700;900&display=swap"
      rel="stylesheet"
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <title>Astro</title>
    <script is:inline>
      {
        const stored = localStorage.getItem("theme");
        const theme =
          stored === "light" || stored === "dark" || stored === "system"
            ? stored
            : "system";
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)"
        ).matches;
        const isDark =
          theme === "dark" || (theme === "system" && prefersDark);
        document.documentElement.classList.toggle("dark", isDark);
        document
          .querySelector('meta[name="color-scheme"]')
          ?.setAttribute(
            "content",
            theme === "system" ? "light dark" : theme
          );
        document.documentElement.dataset.theme = theme;
      }
    </script>
  </head>
  <body
    class="font-sans p-6 sm:p-12 md:p-16 2xl:p-32 bg-white text-gray-900 dark:bg-gray-900 dark:text-gray-100"
  >
    <div id="theme-toggle" class="fixed z-50">
      <button
        id="theme-button"
        type="button"
        aria-controls="theme-menu"
        aria-expanded="false"
        aria-haspopup="menu"
        aria-label="表示モードを切り替える"
        class="relative flex size-11 cursor-pointer items-center justify-center bg-white text-gray-900 dark:bg-gray-900 dark:text-gray-100"
      >
        <svg
          data-theme-icon="light"
          aria-hidden="true"
          viewBox="0 0 24 24"
          class="size-5 fill-none stroke-current"
          stroke-width="1.5"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            stroke-linecap="round"
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
          ></path>
        </svg>
        <svg
          data-theme-icon="dark"
          aria-hidden="true"
          viewBox="0 0 24 24"
          class="size-5 fill-none stroke-current"
          stroke-width="1.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21 14.5A8.5 8.5 0 0 1 9.5 3 7 7 0 1 0 21 14.5Z"
          ></path>
        </svg>
        <svg
          data-theme-icon="system"
          aria-hidden="true"
          viewBox="0 0 24 24"
          class="size-5 fill-none stroke-current"
          stroke-width="1.5"
        >
          <rect x="3" y="4" width="18" height="12" rx="1.5"></rect>
          <path stroke-linecap="round" d="M8 20h8M12 16v4"></path>
        </svg>
      </button>
      <div
        id="theme-menu"
        role="menu"
        aria-labelledby="theme-button"
        hidden
        class="absolute top-full right-0 mt-2 flex min-w-36 flex-col border border-gray-900 bg-white shadow-md dark:border-gray-100 dark:bg-gray-900"
      >
        <button
          type="button"
          role="menuitemradio"
          aria-checked="false"
          data-theme="light"
          class="flex h-11 cursor-pointer items-center gap-3 px-3 text-left text-gray-900 dark:text-gray-100"
        >
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            class="size-5 shrink-0 fill-none stroke-current"
            stroke-width="1.5"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <path
              stroke-linecap="round"
              d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
            ></path>
          </svg>
          <span>ライト</span>
        </button>
        <button
          type="button"
          role="menuitemradio"
          aria-checked="false"
          data-theme="dark"
          class="flex h-11 cursor-pointer items-center gap-3 px-3 text-left text-gray-900 dark:text-gray-100"
        >
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            class="size-5 shrink-0 fill-none stroke-current"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21 14.5A8.5 8.5 0 0 1 9.5 3 7 7 0 1 0 21 14.5Z"
            ></path>
          </svg>
          <span>ダーク</span>
        </button>
        <button
          type="button"
          role="menuitemradio"
          aria-checked="false"
          data-theme="system"
          class="flex h-11 cursor-pointer items-center gap-3 px-3 text-left text-gray-900 dark:text-gray-100"
        >
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            class="size-5 shrink-0 fill-none stroke-current"
            stroke-width="1.5"
          >
            <rect x="3" y="4" width="18" height="12" rx="1.5"></rect>
            <path stroke-linecap="round" d="M8 20h8M12 16v4"></path>
          </svg>
          <span>システム</span>
        </button>
      </div>
    </div>
    <h1
      class="text-logo font-zen header_logo w-fit pb-6 sm:pb-12 md:pb-16 2xl:pb-32"
    >
	タカハシ<br />
        タカユキ<br />
        のポート<br />
        フォリオ
    </h1>
    <nav
      id="fixed-nav"
      aria-label="ページ内ナビゲーション"
      class="fixed z-50 flex flex-col-reverse items-end gap-2 font-sans font-light text-gray-900 dark:text-gray-100"
    >
      <div class="flex w-[10rem] flex-col-reverse border border-gray-900 bg-white text-right shadow-md dark:border-gray-100 dark:bg-gray-900 lg:border-0 lg:shadow-none">
        <button
          id="menu-button"
          type="button"
          aria-controls="fixed-nav-list"
          aria-expanded="false"
          class="text-body w-full p-4 lg:hidden"
        >
          目次
        </button>
        <ul
          id="fixed-nav-list"
          class="text-body grid gap-2 p-4 max-lg:hidden"
        >
          {
            navItems.map((item) => (
              <li>
                <a href={item.href}>{item.label}</a>
              </li>
            ))
          }
        </ul>
      </div>
    </nav>
    <main>
      <section id="section01" class="border-t border-gray-900 dark:border-gray-100 mt-[8rem]">
		<hgroup>
			<p class="section-number text-body mt-[0.5em]">[01]</p>
			<h2 class="text-display section-inset-x mt-[4rem]">はじめに</h2>
		</hgroup>
        <div class="section-inset-x mt-[4rem]">
          <div class="text-body font-sans font-light">
            <p>
              はじめまして。タカハシタカユキと申します。<br />
              東京都在住で、フロントエンドエンジニアとして働いています。<br />
              業務歴は2年で、主にWordPressを使用したサイト制作を行っています。<br
              />
              アクセシビリティとモダンフロントエンドに興味があり、日々勉強中です。
            </p>
          </div>
        </div>
      </section>
      <section id="section02" class="border-t border-gray-900 dark:border-gray-100 mt-[8rem]">
		<hgroup>
			<p class="section-number text-body mt-[0.5em]">[02]</p>
			<h2 class="text-display section-inset-x mt-[4rem]">略歴</h2>
		</hgroup>
        <div class="section-inset-x mt-[4rem]">
          <div class="text-body font-sans font-light">
            <section>
              <h3 class="text-body font-medium mt-8">2011年 - 2017年</h3>
              <p>
                大学卒業後、飲食店でフリーターをしており、個人で飲食店を開業することを目指していました。
              </p>
            </section>
            <section>
              <h3 class="text-body font-medium mt-8">2017年 - 2019</h3>
              <p>
                事務職として勤務する中でVBAを独学し、プログラミングへの興味を持ち始めました。
              </p>
            </section>
            <section>
              <h3 class="text-body font-medium mt-8">2019年 - 2021年</h3>
              <p>
                RubyとRuby on
                Railsを学習し、受託制作会社へ入社しましたが、不眠症に陥り、早期退職しました。
              </p>
            </section>
            <section>
              <h3 class="text-body font-medium mt-8">2021年 - 2023年</h3>
              <p>
                療養し、社会復帰しつつ、Webの勉強を再開しました。<br />
                バックエンドよりもフロントエンドへの興味が元々強かったため、Web制作の勉強を再開しました。
              </p>
            </section>
            <section>
              <h3 class="text-body font-medium mt-8">2023年 - 現在</h3>
              <p>
                東京のWeb制作会社に入社し、フロントエンドエンジニアとして働いています。<br
                />
                フロントエンドエンジニアとして、ユーザーに優れた体験を提供することに情熱を持っています。
              </p>
            </section>
          </div>
        </div>
      </section>
      <section id="section03" class="border-t border-gray-900 dark:border-gray-100 mt-[8rem]">
		<hgroup>
			<p class="section-number text-body mt-[0.5em]">[03]</p>
			<h2 class="text-display section-inset-x mt-[4rem]">業務経歴</h2>
		</hgroup>
        <div class="section-inset-x mt-[4rem]">
          <div class="text-body font-sans font-light">
            <h3 class="text-body font-medium mt-8">
              小規模〜中規模サイトの制作
            </h3>
            <p>
              30ページ程度の規模のサイトを数件作成しました。
              WordPress構築も行いました。
            </p>
            <h3 class="text-body font-medium mt-8">アクセシビリティ対応</h3>
            <p>
              jis規格に基づいて、うwcag2.0に準拠することを目指したアクセシビリティ対応を行いました。
              外部機関のチェック結果を元に、優先度を設定し、対応を行いました。
            </p>
            <h3 class="text-body font-medium mt-8">API連携</h3>
            <p>
              IR情報のCMS管理サービスのAPIを連携し、サイトに表示させる業務
              APIが簡略的なものしかなかった
              各会社の決算期に基づいてデータを割り振り、セレクト要素で表示させるようにする
              ゼロイチで作成することはほとんどなく、既存のコードを流用することが多かった
            </p>
          </div>
        </div>
      </section>
      <section id="section04" class="border-t border-gray-900 dark:border-gray-100 mt-[8rem]">
		<hgroup>
			<p class="section-number text-body mt-[0.5em]">[04]</p>
			<h2 class="text-display section-inset-x mt-[4rem]">強み</h2>
		</hgroup>
        <div class="section-inset-x mt-[4rem]">
          <div class="text-body font-sans font-light">
            <section>
              <h3 class="text-body font-medium mt-8">
                アクセシビリティへの関心
              </h3>
              <p>
                イベントに参加し、アクセシビリティに関する知識を深めています。<br
                />
                Trusted Testerに合格しました。<br />
                なぜ関心を持ったのか：本質的だと思った。どんなにカッコいい演出のサイトを作成しても、それが見えない人にとっては使いものにならない。それでは意味がない。
              </p>
            </section>
            <section>
              <h3 class="text-body font-medium mt-8">
                モダンフロントエンドへの関心
              </h3>
              <p>
                イベントに参加し、モダンフロントエンドに関する知識を深めています。<br
                />
                モダンフロントエンドに関する知識を深めています。<br />
                なぜ関心を持ったのか：モダンフロントエンドに関する知識を深めています。
              </p>
            </section>
            <section>
              <h3 class="text-body font-medium mt-8">バックエンドの学習経験</h3>
              <p>
                バックエンドの学習経験：Ruby,Ruby on
                Rails,PHP,Laravel,Node.js,Express,MySQL,PostgreSQL,MongoDB
              </p>
            </section>
          </div>
        </div>
      </section>
      <section id="section05" class="border-t border-gray-900 dark:border-gray-100 mt-[8rem]">
		<hgroup>
			<p class="section-number text-body mt-[0.5em]">[05]</p>
			<h2 class="text-display section-inset-x mt-[4rem]">成果物</h2>
		</hgroup>
        <div class="section-inset-x mt-[4rem]">
          <div class="text-body font-sans font-light">
            <h3 class="text-body font-medium mt-8">技術ブログ</h3>
            <a href="https://front-dispatch.vercel.app/" target="_blank"
              class="underline" >https://front-dispatch.vercel.app/</a
            >
            <p>
              業務の中でぶつかった問題、解決策をブログに書いています。<br />
              アクセシビリティに関する記事が多いです。
            </p>
            <h3 class="text-body font-medium mt-8">会議室予約システム</h3>
            <a href="" class="underline">https://front-dispatch.com/</a>
            <p>
              next.js,supabaseを使用して会議室予約アプリを作成しました。<br />
              過去にバックエンドを学習していたことと、AIが進化したことによって、作成に至りました。<br
              />
            </p>
          </div>
        </div>
      </section>
    </main>
    <footer id="site-footer" class="border-t border-gray-900 pt-[8rem] mt-[8rem] dark:border-gray-100">
      <div class="flex flex-col items-start gap-[6rem] sm:flex-row sm:items-start sm:justify-between">
        <p class="text-logo font-zen header_logo">
          タカハシ<br />
          タカユキ<br />
          のポート<br />
          フォリオ
        </p>
        <nav
          aria-label="フッターナビゲーション"
          class="text-body w-[10rem] bg-white text-left font-sans font-light text-gray-900 dark:bg-gray-900 dark:text-gray-100 sm:text-right"
        >
          <ul class="grid gap-2 lg:p-4 pt-0">
            {
              navItems.map((item) => (
                <li>
                  <a href={item.href}>{item.label}</a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
      <div
        class="mt-16 flex items-center justify-end gap-3 text-right font-sans font-light"
      >
        <p class="text-caption">This site was developed by</p>
        <a
          href="https://github.com/tktkaws"
          target="_blank"
          rel="noreferrer"
          aria-label="GitHub"
        >
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            class="size-6 fill-current"
          >
            <path
              d="M12 2C6.48 2 2 6.59 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.09.68-.22.68-.49 0-.24-.01-.88-.01-1.73-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.57 2.36 1.12 2.93.86.09-.67.35-1.12.63-1.38-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.38 9.38 0 0 1 12 7c.85 0 1.7.12 2.5.34 1.9-1.33 2.74-1.05 2.74-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.93-2.34 4.79-4.57 5.05.36.32.68.95.68 1.92 0 1.38-.01 2.5-.01 2.84 0 .27.18.59.69.49A10.08 10.08 0 0 0 22 12.25C22 6.59 17.52 2 12 2Z"
            ></path>
          </svg>
        </a>
      </div>
    </footer>

    <script>
      const fixedNav = document.querySelector("#fixed-nav");
      const menuButton = document.querySelector("#menu-button");
      const fixedNavList = document.querySelector("#fixed-nav-list");
      const footer = document.querySelector("#site-footer");
      const themeToggle = document.querySelector("#theme-toggle");
      const themeButton = document.querySelector("#theme-button");
      const themeMenu = document.querySelector("#theme-menu");
      const colorSchemeMeta = document.querySelector(
        'meta[name="color-scheme"]'
      );
      const themeMedia = window.matchMedia("(prefers-color-scheme: dark)");

      type Theme = "light" | "dark" | "system";

      const isTheme = (value: string | null): value is Theme =>
        value === "light" || value === "dark" || value === "system";

      const getStoredTheme = (): Theme => {
        const stored = localStorage.getItem("theme");
        return isTheme(stored) ? stored : "system";
      };

      const resolveIsDark = (theme: Theme) =>
        theme === "dark" || (theme === "system" && themeMedia.matches);

      const themeLabels = {
        light: "ライト",
        dark: "ダーク",
        system: "システム",
      } as const;

      const syncThemeUi = (theme: Theme) => {
        if (!(themeButton instanceof HTMLElement)) return;

        themeButton.setAttribute(
          "aria-label",
          `表示モードを切り替える（現在: ${themeLabels[theme]}）`
        );

        themeMenu?.querySelectorAll("[data-theme]").forEach((item) => {
          if (!(item instanceof HTMLElement)) return;
          const selected = item.getAttribute("data-theme") === theme;
          item.setAttribute("aria-checked", String(selected));
          item.classList.toggle("bg-gray-100", selected);
          item.classList.toggle("dark:bg-gray-800", selected);
        });
      };

      const applyTheme = (theme: Theme, persist = true) => {
        document.documentElement.classList.toggle("dark", resolveIsDark(theme));
        document.documentElement.dataset.theme = theme;
        colorSchemeMeta?.setAttribute(
          "content",
          theme === "system" ? "light dark" : theme
        );

        if (persist) {
          localStorage.setItem("theme", theme);
        }

        syncThemeUi(theme);
      };

      if (themeToggle && themeButton instanceof HTMLElement && themeMenu instanceof HTMLElement) {
        const getMenuItems = () =>
          Array.from(
            themeMenu.querySelectorAll<HTMLElement>("[role='menuitemradio']")
          );

        const isMenuOpen = () =>
          themeButton.getAttribute("aria-expanded") === "true";

        const focusCurrentOrFirstItem = () => {
          const items = getMenuItems();
          const checkedItem = items.find(
            (item) => item.getAttribute("aria-checked") === "true"
          );
          (checkedItem ?? items[0])?.focus();
        };

        const setThemeMenuOpen = (isOpen: boolean, focusTarget?: "current" | "button") => {
          themeMenu.hidden = !isOpen;
          themeButton.setAttribute("aria-expanded", String(isOpen));

          if (!isOpen) {
            if (focusTarget === "button") {
              themeButton.focus();
            }
            return;
          }

          if (focusTarget === "current") {
            focusCurrentOrFirstItem();
          }
        };

        const selectTheme = (theme: Theme) => {
          applyTheme(theme);
          setThemeMenuOpen(false, "button");
        };

        applyTheme(getStoredTheme(), false);

        themeButton.addEventListener("click", () => {
          if (isMenuOpen()) {
            setThemeMenuOpen(false);
            return;
          }

          setThemeMenuOpen(true, "current");
        });

        themeMenu.addEventListener("click", (event) => {
          const target = event.target;

          if (!(target instanceof Element)) return;

          const option = target.closest("[data-theme]");
          const theme = option?.getAttribute("data-theme");

          if (!isTheme(theme)) return;

          selectTheme(theme);
        });

        themeMenu.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            event.preventDefault();
            setThemeMenuOpen(false, "button");
          }
        });

        themeToggle.addEventListener("focusout", (event) => {
          if (!isMenuOpen()) return;

          const nextTarget = event.relatedTarget;

          if (nextTarget instanceof Node && themeToggle.contains(nextTarget)) {
            return;
          }

          setThemeMenuOpen(false);
        });

        document.addEventListener("click", (event) => {
          const target = event.target;

          if (
            target instanceof Node &&
            !themeToggle.contains(target) &&
            isMenuOpen()
          ) {
            setThemeMenuOpen(false);
          }
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape" && isMenuOpen()) {
            event.preventDefault();
            setThemeMenuOpen(false, "button");
          }
        });

        themeMedia.addEventListener("change", () => {
          if (getStoredTheme() === "system") {
            applyTheme("system", false);
          }
        });
      }

      if (fixedNav && menuButton && fixedNavList) {
        const setMenuOpen = (isOpen: boolean) => {
          fixedNavList.classList.toggle("max-lg:hidden", !isOpen);
          menuButton.setAttribute("aria-expanded", String(isOpen));
          menuButton.textContent = isOpen ? "閉じる" : "目次";
        };

        menuButton.addEventListener("click", () => {
          setMenuOpen(menuButton.getAttribute("aria-expanded") !== "true");
        });

        fixedNavList.addEventListener("click", (event) => {
          const target = event.target;

          if (target instanceof HTMLAnchorElement) {
            setMenuOpen(false);
          }
        });

        document.addEventListener("click", (event) => {
          const target = event.target;

          if (
            target instanceof Node &&
            !fixedNav.contains(target) &&
            menuButton.getAttribute("aria-expanded") === "true"
          ) {
            setMenuOpen(false);
          }
        });

        document.addEventListener("keydown", (event) => {
          if (
            event.key === "Escape" &&
            menuButton.getAttribute("aria-expanded") === "true"
          ) {
            setMenuOpen(false);
          }
        });
      }

      if (fixedNav && footer) {
        const setFixedNavVisibility = (isFooterVisible: boolean) => {
          fixedNav.classList.toggle("fixed-nav-hidden", isFooterVisible);
          fixedNav.setAttribute("aria-hidden", String(isFooterVisible));
        };

        const isFooterInView = () => {
          const rect = footer.getBoundingClientRect();
          return rect.top < window.innerHeight && rect.bottom > 0;
        };

        const revealFixedNav = () => {
          setFixedNavVisibility(isFooterInView());
          document.documentElement.classList.add("fixed-nav-ready");
        };

        const observer = new IntersectionObserver(([entry]) => {
          setFixedNavVisibility(entry.isIntersecting);
        });
        observer.observe(footer);

        if (document.readyState === "complete") {
          revealFixedNav();
        } else {
          window.addEventListener("load", revealFixedNav, { once: true });
        }

        window.addEventListener("pageshow", () => {
          if (document.documentElement.classList.contains("fixed-nav-ready")) {
            setFixedNavVisibility(isFooterInView());
          }
        });
      } else {
        document.documentElement.classList.add("fixed-nav-ready");
      }
    </script>
  </body>
</html>
